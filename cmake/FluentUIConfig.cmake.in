@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# find_dependency mirrors exactly the flags FluentUI was built with (brief 26-B),
# so a downstream find_package(FluentUI) pulls only the deps that are actually
# linked. ZLIB / SDL3_image dropped (brief 26-A): ZLIB comes transitively via
# Freetype; SDL3_image was unused (image loading is vendored stb_image).
find_dependency(Freetype CONFIG)
if(@FLUENTUI_BACKEND_GL@)
    find_dependency(OpenGL)
endif()
if(@FLUENTUI_BACKEND_VULKAN@)
    find_dependency(Vulkan)
endif()
if(@FLUENTUI_PLATFORM_SDL@)
    find_dependency(SDL3 CONFIG)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/FluentUITargets.cmake")

check_required_components(FluentUI)
